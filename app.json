{
  "expo": {
    "name": "minaroute",
    "slug": "minaroute",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "minaroute",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.minaroute.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Minaroute uses your location to find Muslim-friendly places near you, and during Umrah to gently guide you to each rite and the right gate.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow location while Manasik runs in the background so it can gently let you know when you've reached a rite site — even if the app isn't open. You can always guide yourself manually.",
        "LSApplicationQueriesSchemes": [
          "comgooglemaps",
          "maps"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ],
      "package": "com.minaroute.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "name": "MinaRoute",
      "shortName": "MinaRoute",
      "description": "Find mosques, halal food, and Islamic schools near you",
      "lang": "en",
      "themeColor": "#0850FD",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0850FD",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Minaroute uses your location to find Muslim-friendly places near you, and during Umrah to gently guide you to each rite and the right gate.",
          "locationAlwaysAndWhenInUsePermission": "Allow location while Manasik runs in the background so it can gently let you know when you've reached a rite site — even if the app isn't open. You can always guide yourself manually.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#12664F"
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-maps",
      "expo-sqlite",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "984fc7a4-af4a-4a43-813a-0e0fdfc614ff"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/984fc7a4-af4a-4a43-813a-0e0fdfc614ff"
    }
  }
}

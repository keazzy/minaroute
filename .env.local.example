# Copy this file to .env.local and fill in your actual keys
# Command: cp .env.local.example .env.local

# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=paste_your_google_key_here

# Get from: Supabase Dashboard > Settings > API > service_role (secret)
SUPABASE_SERVICE_KEY=paste_your_supabase_service_key_here
GOOGLE_MAPS_KEY=
